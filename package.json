{
  "name": "react-tailwind-ghpages-starter",
  "version": "1.0.0",
  "description": "Barebones starter for a React/Tailwind CSS PWA hosted via GitHub Pages. Uses GitHub Actions to build and deploy site.",
  "private": true,
  "engines": {
    "node": ">= 24.x",
    "npm": ">= 11.x"
  },
  "packageManager": "npm@12.0.1",
  "type": "module",
  "scripts": {
    "build": "nubx tsc -b && nubx vite build",
    "clean": "rm -rf ./build",
    "dev": "nubx vite serve",
    "format": "nubx oxfmt src",
    "format:check": "nubx oxfmt --check src",
    "lint": "nubx oxlint src",
    "prebuild": "nub run clean",
    "preview": "nubx vite preview",
    "start": "nub run dev",
    "test": "nub run format:check && nub run lint && nub run typecheck",
    "typecheck": "nubx tsc --noEmit"
  },
  "repository": {
    "url": "https://github.com/mikesprague/react-tailwind-ghpages-starter"
  },
  "keywords": [],
  "author": {
    "name": "Michael Sprague",
    "email": "mikesprague@gmail.com"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/mikesprague/react-tailwind-ghpages-starter/issues"
  },
  "homepage": "https://mikesprague.github.io/react-tailwind-ghpages-starter",
  "dependencies": {
    "@fontsource-variable/inter": "5.2.8",
    "@nubjs/nub": "0.4.13",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "dayjs": "1.11.21",
    "he": "1.2.0",
    "jotai": "2.20.2",
    "lucide-react": "1.24.0",
    "nanoid": "6.0.0",
    "radix-ui": "1.6.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-icons": "5.7.0",
    "shadcn": "4.13.0",
    "tailwind-merge": "3.6.0",
    "tw-animate-css": "1.4.0"
  },
  "devDependencies": {
    "@nubjs/types": "0.4.12",
    "@tailwindcss/typography": "0.5.20",
    "@tailwindcss/vite": "4.3.2",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "cssnano": "8.0.2",
    "cz-git": "1.13.1",
    "globals": "17.7.0",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "tailwindcss": "4.3.2",
    "typescript": "7.0.2",
    "vite": "8.1.5",
    "vite-plugin-html": "3.2.2",
    "vite-plugin-pwa": "1.3.0"
  },
  "overrides": {
    "glob": "^13.0.6"
  },
  "allowScripts": {
    "@nubjs/nub": true,
    "fsevents@2.3.3": true
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-git"
    }
  },
  "volta": {
    "node": "26.5.0",
    "npm": "12.0.1"
  }
}
